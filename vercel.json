{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/frontend/index.html"
    },
    { "source": "/app", "destination": "/frontend/app.html" },
    { "source": "/app/", "destination": "/frontend/app.html" },
    { "source": "/frontend/app", "destination": "/frontend/app.html" },
    { "source": "/frontend/app/", "destination": "/frontend/app.html" }
  ],
  "headers": [
    {
      "source": "/frontend/(.*)\\.(js|css|svg|png|jpg|jpeg|gif|webp|ico|woff2?)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
